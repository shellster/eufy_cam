[eufy]
# Eufy cloud account credentials.
username = "email@example.com"
password = "secret123"

# Country and language for the Eufy API. Defaults: "US", "en"
country = "US"
language = "en"

# Name shown in Eufy's trusted devices list. Cosmetic only, defaults to empty.
trusted_device_name = ""

[server]
# Address to bind the HTTP server on. Default: "0.0.0.0"
host = "0.0.0.0"
# Port for the HTTP server. Default: 8080
port = 8080
# Enable verbose debug logging. Default: false
# debug = true

[p2p]
# Local UDP port for P2P communication with stations/cameras.
# 0 = OS picks a random ephemeral port. Default: 0
# Set a specific port only if you need to configure firewall rules.
local_port = 0

# How to connect to the station. Default: 2
#   1 = OnlyLocal  — only connect if station is on the same LAN
#   2 = Quickest   — try LAN first, then fall back to cloud relay
connection_type = 2

# Timeouts for P2P connections (increase for internet/cloud relay paths).
# All values in seconds unless noted.

# How long to wait for a P2P connection to establish. Default: 60
# connection_timeout = 60

# How long to wait for encryption handshake after connecting. Default: 30
# encryption_timeout = 30

# Maximum number of discovery attempts (3s interval between each). Default: 30
# discovery_attempts = 30

# How long to wait for a command ACK before dropping it. Default: 15
# ack_timeout = 15

[auth]
# Optional HTTP auth for the server's API endpoints.
# type = "digest"    # enables digest auth (omit to disable)
# username = "admin"
# password = "secret"

[stream]
# Public streaming port — serves MPEG-TS with no auth.
# Streams auto-start on connect, teardown after last client leaves (30s grace).
# enabled = true
# port = 8090
# bind = "0.0.0.0"
